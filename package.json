{
  "name": "sonarfc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:fresh": "sh ./scripts/dev-fresh.sh",
    "build": "next build",
    "start": "next start",
    "start:preview": "next start --hostname 0.0.0.0 --port 3001",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next tsconfig.tsbuildinfo",
    "verify": "npm run clean && npm run typecheck && npm run build",
    "review": "sh ./scripts/review-preview.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.4"
  }
}
